# ==============================================================
#  SMART HOME — Backend Environment Configuration
#  Copy this file to `.env` and fill in the values.
#  Never commit your actual `.env` file to version control!
# ==============================================================


# ==============================
# APPLICATION
# ==============================

PORT=8080                         # Port on which the server runs (default: 8080)
NODE_ENV=development              # Environment mode: development | production | staging
APP_SECRET=                       # Application secret for internal encryption or token generation
APP_URL=                          # Full URL of this backend server (e.g. http://localhost:8080)
PUBLIC_URL=                       # Public base URL for assets / API domain


# ==============================
# AUTHENTICATION & JWT
# ==============================

JWT_SECRET=                       # Secret key used for signing and verifying JWT tokens (keep this strong & random)
EXPIRES_IN_SHORT="2 d"            # Short-lived access token expiry (e.g. "2 d", "15 m", "1 h")
EXPIRES_IN_LONG="7 d"             # Long-lived refresh token expiry  (e.g. "7 d", "30 d")
SHORT_EXPIRES_IN="2m"             # Very short-lived token expiry used for one-time operations (e.g. "2m")


# ==============================
# DATABASE
# ==============================

MONGO_URI=                        # MongoDB connection URI (e.g. mongodb+srv://user:pass@cluster.mongodb.net/dbname)
DB_NAME=                          # MongoDB database name


# ==============================
# CORS
# ==============================

CORS_ORIGINS=http://localhost:3000 # Comma-separated list of allowed frontend origins (no trailing slashes)
                                   # Example: http://localhost:3000,https://yourdomain.com


# ==============================
# EMAIL (SMTP)
# ==============================

FROM_EMAIL=                       # Default "from" email address for outgoing mail (e.g. no-reply@smarthome.com)
MAIL_HOST=mail.privateemail.com   # SMTP host (e.g. smtp.gmail.com or mail.privateemail.com)
MAIL_PORT=587                     # SMTP port: 587 (TLS/STARTTLS) or 465 (SSL)
MAIL_USERNAME=                    # SMTP login username (usually your email address)
MAIL_PASSWORD=                    # SMTP login password or app-specific password
SUPPORT_EMAIL=support@smarthome.com  # Email address displayed in support communications
TOKEN_EXPIRY_MINUTES=10           # How many minutes a verification / OTP token is valid


# ==============================
# TRANSACTIONAL EMAIL & SMS
# ==============================

SEND_MAIL_API_KEY=                # API key for third-party email service (e.g. SendGrid, Mailgun) — optional
SEND_MAIL_SMS_PHONE=              # Sender phone number / ID for SMS notifications


# ==============================
# CLOUDINARY (File Uploads)
# ==============================

CLOUDINARY_NAME=                  # Cloudinary cloud name (found in your Cloudinary dashboard)
CLOUDINARY_API_KEY=               # Cloudinary API key
CLOUDINARY_SECRET=                # Cloudinary API secret
CLOUDINARY_FOLDER=smart-home      # Default Cloudinary folder name for uploaded files


# ==============================
# GOOGLE OAUTH
# ==============================

GOOGLE_CLIENT_ID=                 # Google OAuth 2.0 client ID (from Google Cloud Console)
GOOGLE_CLIENT_SECRET=             # Google OAuth 2.0 client secret
GOOGLE_REDIRECT_URI=              # Authorized redirect URI (e.g. http://localhost:8080/api/auth/google-auth/callback)
GOOGLE_CALLBACK_URL=              # Alias / fallback for the Google OAuth callback URL
GOOGLE_PROFILE="https://www.googleapis.com/oauth2/v1/userinfo"
                                  # Google endpoint to fetch user profile (usually unchanged)
GOOGLE_LOGIN_FAILURE_REDIRECT=    # URL to redirect users to if Google login fails


# ==============================
# PAYSTACK (Payment Gateway)
# ==============================

PAYSTACK_SECRET_KEY=              # Paystack secret key (starts with sk_live_ or sk_test_)
PAYSTACK_WEBHOOK_SECRET_KEY=      # Paystack webhook signing secret for verifying webhook payloads
PAYSTACK_API_URL=https://api.paystack.co  # Paystack API base URL (do not change)


# ==============================
# FLUTTERWAVE (Payment Gateway)
# ==============================

FLUTTERWAVE_SECRET_KEY=           # Flutterwave secret key (from Flutterwave dashboard)
FLUTTERWAVE_SECRET_HASH=          # Flutterwave webhook secret hash for payload verification


# ==============================
# STRIPE (Payment Gateway)
# ==============================

STRIPE_API_KEY=                   # Stripe secret API key (sk_live_... or sk_test_...)
STRIPE_PUBLISHABLE_KEY=           # Stripe publishable key (pk_live_... or pk_test_...)
STRIPE_WEBHOOK_SECRET=            # Stripe webhook signing secret (from Stripe dashboard → Webhooks)
STRIPE_LINK=                      # Optional: Stripe payment link URL


# ==============================
# VERIFYME (KYC / Identity)
# ==============================

VERIFYME_API_URL=https://vapi.verifyme.ng   # VerifyMe API base URL (do not change)
VERIFYME_SECRET_KEY=              # VerifyMe secret key for KYC API authentication


# ==============================
# ENCRYPTION
# ==============================

ENCRYPTION_SECRET=                # Secret key used for data encryption/decryption (use a random 32-char string)
ENCRYPTION_ALGO=aes-256-cbc       # Encryption algorithm (default: aes-256-cbc)


# ==============================
# FRONTEND & ADMIN URLS
# ==============================

FRONTEND_URL=http://localhost:3000        # Main frontend application URL (used in emails & redirects)
FRONT_END_URL=http://localhost:3000       # Alias for FRONTEND_URL (some services use this)
MARKETING_FRONTEND_LINK=          # Marketing site or landing page URL
ADMIN_DASH=                       # Admin dashboard URL (used in admin registration emails)


# ==============================
# PERMISSION MANAGEMENT
# ==============================

PERMISSION_MODULES=Dashboard,User Management,Property Management,Payment Management,Analytics
                                  # Comma-separated list of modules that require permission control
PERMISSION_SYNC=false             # Set to 'true' to auto-sync permissions to the DB on server startup
DEFAULT_ACCESS_LEVELS=full,restricted,create,delete,update,none
                                  # Default access levels applied when permission modules are seeded
