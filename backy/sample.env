# ==============================
# APPLICATION CONFIGURATION
# ==============================

PORT=4000                     # Port on which the server runs (default: 4000)
NODE_ENV=development           # Environment mode: development | production | staging
APP_SECRET=                    # Application secret for internal encryption or token generation


# ==============================
# AUTHENTICATION
# ==============================

JWT_SECRET=                    # Secret key used for signing and verifying JWT tokens
EXPIRES_IN_SHORT="2 d"         # Short-lived token expiry duration (e.g. 2 days)
EXPIRES_IN_LONG="7 d"          # Long-lived token expiry duration (e.g. 7 days)


# ==============================
# EMAIL CONFIGURATION
# ==============================

FROM_EMAIL=                    # Default "from" email address used in outgoing mails
MAIL_HOST=mail.privateemail.com # SMTP host for email delivery (PrivateEmail by default)
MAIL_PORT=587                  # SMTP port (587 for TLS, 465 for SSL)
MAIL_USERNAME=                 # SMTP username (usually your email address)
MAIL_PASSWORD=                 # SMTP password or app-specific password


# ==============================
# CLOUDINARY CONFIGURATION
# ==============================

CLOUDINARY_NAME=               # Cloudinary account name
CLOUDINARY_API_KEY=            # Cloudinary API key
CLOUDINARY_SECRET=             # Cloudinary API secret
CLOUDINARY_FOLDER=             # Default folder name for storing uploaded images


# ==============================
# DATABASE CONFIGURATION
# ==============================

MONGO_URI=                     # MongoDB connection URI (e.g. mongodb+srv://user:pass@cluster/db)
DB_NAME=                       # MongoDB database name


# ==============================
# PERMISSION MANAGEMENT
# ==============================

PERMISSION_MODULES=Dashboard,User Management,Order Management,Analytics,Product Management,Financial Management
                              # List of application modules that require permission control (comma-separated)

PERMISSION_SYNC=false          # Set to 'true' to auto-sync permissions from env to MongoDB on startup

DEFAULT_ACCESS_LEVELS=full,restricted,create,delete,update,none
                              # Default access levels applied when new modules are seeded


# ==============================
# GOOGLE AUTHENTICATION
# ==============================

GOOGLE_CLIENT_ID=              # Google OAuth client ID
GOOGLE_CLIENT_SECRET=          # Google OAuth client secret
GOOGLE_PROFILE="https://www.googleapis.com/oauth2/v1/userinfo"
                              # Endpoint to fetch authenticated user profile from Google


# ==============================
# STRIPE PAYMENT CONFIGURATION
# ==============================

STRIPE_API_KEY=                # Stripe API secret key for payment processing
STRIPE_WEBHOOK_SECRET=         # Stripe webhook signing secret for verifying event payloads


# ==============================
# VERIFYME (KYC / IDENTITY)
# ==============================

VERIFYME_API_URL=`https://vapi.verifyme.ng`
                              # VerifyMe API base URL (do not change)
VERIFYME_SECRET_KEY=           # VerifyMe secret key for authentication


# ==============================
# FRONT-END & ADMIN DASHBOARD
# ==============================

ADMIN_DASH="https://www.qartt.com"
                              # Admin dashboard URL for redirection or deep linking
FRONT_END_URL=                 # Public-facing frontend URL (used in emails and CORS setup)
PUBLIC_URL=                    # Base URL of your public assets or API domain


# ==============================
# MAIL / SMS SERVICES
# ==============================

SEND_MAIL_API_KEY=             # API key for third-party transactional email service (optional)
SEND_MAIL_SMS_PHONE=           # Phone number used as sender ID for SMS notifications


